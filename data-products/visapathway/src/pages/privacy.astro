---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy Policy — VisaPathway" description="Privacy policy for VisaPathway visa checker tool.">
  <h1>Privacy Policy</h1>
  <p style="color: var(--muted);">Last updated: April 15, 2026</p>
  <section style="max-width: 750px;">
    <h2>Your Data Stays in Your Browser</h2>
    <p>All visa lookups happen <strong>entirely in your browser</strong>. Your passport nationalities, residence permits, and destination selections are never sent to any server. We do not collect, store, or transmit your travel document information.</p>

    <h2>Analytics</h2>
    <p>We use privacy-respecting analytics to understand which features are popular. This includes pages visited, country/region, device type, and referral source. We do not track individuals across sessions.</p>

    <h2>Contact</h2>
    <p>Privacy questions: <strong>contact@techtools365.com</strong></p>
  </section>
</BaseLayout>
