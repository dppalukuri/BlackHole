---
import AdScripts from '../components/AdScripts.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  keywords?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  keywords,
  jsonLd,
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://visapathway.techtools365.com';
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).toString();
const og = ogImage || `${siteUrl}/og-default.png`;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />

  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="author" content="TechTools365" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="googlebot" content="index, follow" />
  <meta name="google-adsense-account" content="ca-pub-9446467058878539" />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="VisaPathway — TechTools365" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={og} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:locale:alternate" content="en_IN" />
  <meta property="og:locale:alternate" content="en_AE" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={og} />

  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%237c3aed'/><text x='16' y='22' font-family='Arial' font-size='14' font-weight='bold' fill='white' text-anchor='middle'>VP</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <AdScripts />

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <slot name="head" />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <div class="brand-stack">
        <a href="https://techtools365.com/" target="_blank" rel="noopener" class="brand" aria-label="TechTools365 — home">
          <span class="brand-mark">T</span>
          <span class="brand-text">Tech<span class="brand-accent">Tools</span>365</span>
        </a>
        <span class="brand-divider" aria-hidden="true">/</span>
        <span class="brand-current">VisaPathway</span>
      </div>
      <nav class="hub-nav" aria-label="TechTools365 sites">
        <a href="https://calcstack.techtools365.com/" target="_blank" rel="noopener" class="hub-link">CalcStack</a>
        <a href="https://toolversus.techtools365.com/" target="_blank" rel="noopener" class="hub-link">ToolVersus</a>
        <a href="https://techtools365.com/" target="_blank" rel="noopener" class="hub-link home-link">All tools <span class="ext">↗</span></a>
      </nav>
    </div>
    <nav class="sub-nav" aria-label="VisaPathway sections">
      <div class="sub-nav-inner">
        <a href="/" class={`sub-link ${currentPath === '/' ? 'is-active' : ''}`}>Visa Checker</a>
        <a href="/about/" class={`sub-link ${currentPath.startsWith('/about') ? 'is-active' : ''}`}>About</a>
      </div>
    </nav>
  </header>

  <div class="frame">
    <aside class="rail rail-left" aria-label="Advertisement">
      <div class="rail-inner">
        <div class="rail-label">Ad</div>
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-9446467058878539" data-ad-slot="REPLACE_LEFT_RAIL_SLOT_ID" data-ad-format="vertical" data-full-width-responsive="false"></ins>
      </div>
    </aside>

    <main class="main">
      <slot />
      <aside class="ad-inline" aria-label="Advertisement">
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-9446467058878539" data-ad-slot="REPLACE_INLINE_SLOT_ID" data-ad-format="auto" data-full-width-responsive="true"></ins>
      </aside>
    </main>

    <aside class="rail rail-right" aria-label="Advertisement">
      <div class="rail-inner">
        <div class="rail-label">Ad</div>
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-9446467058878539" data-ad-slot="REPLACE_RIGHT_RAIL_SLOT_ID" data-ad-format="vertical" data-full-width-responsive="false"></ins>
      </div>
    </aside>
  </div>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="https://techtools365.com/" target="_blank" rel="noopener" class="brand">
          <span class="brand-mark">T</span>
          <span class="brand-text">Tech<span class="brand-accent">Tools</span>365</span>
        </a>
        <p class="footer-tag">Multi-passport visa intelligence. Free.</p>
      </div>
      <nav class="footer-links" aria-label="Footer">
        <a href="/about/">About</a>
        <a href="/privacy/">Privacy</a>
        <a href="https://techtools365.com/" target="_blank" rel="noopener">All tools ↗</a>
      </nav>
      <p class="footer-fine">&copy; {new Date().getFullYear()} VisaPathway by TechTools365. Visa requirements can change without notice — always verify with the relevant embassy or consulate before booking travel.</p>
    </div>
  </footer>

  <script is:inline>
    (function () {
      var ads = document.querySelectorAll('ins.adsbygoogle');
      for (var i = 0; i < ads.length; i++) {
        try { (window.adsbygoogle = window.adsbygoogle || []).push({}); } catch (e) {}
      }
    })();
  </script>
</body>
</html>
<style is:global>
  @import '../styles/global.css';
</style>
