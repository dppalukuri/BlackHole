---
import BaseLayout from '../layouts/BaseLayout.astro';

const allCalcs = [
  { slug: 'india/old-vs-new-tax-regime', name: 'Old vs New Tax Regime', country: 'India', tags: 'tax regime compare deductions' },
  { slug: 'india/fire-calculator', name: 'FIRE Calculator', country: 'India', tags: 'fire retire early independence' },
  { slug: 'india/step-up-sip-calculator', name: 'Step-Up SIP Calculator', country: 'India', tags: 'sip step up increase' },
  { slug: 'india/loan-comparison', name: 'Loan Comparison', country: 'India', tags: 'loan compare bank emi' },
  { slug: 'india/sip-calculator', name: 'SIP Calculator', country: 'India', tags: 'sip mutual fund' },
  { slug: 'india/emi-calculator', name: 'EMI Calculator', country: 'India', tags: 'emi loan home car' },
  { slug: 'india/income-tax-calculator', name: 'Income Tax Calculator', country: 'India', tags: 'income tax slab' },
  { slug: 'india/fd-calculator', name: 'FD Calculator', country: 'India', tags: 'fd fixed deposit' },
  { slug: 'india/ppf-calculator', name: 'PPF Calculator', country: 'India', tags: 'ppf provident fund' },
  { slug: 'india/lumpsum-calculator', name: 'Lump Sum Calculator', country: 'India', tags: 'lumpsum one time' },
  { slug: 'uae/gratuity-calculator', name: 'UAE Gratuity Calculator', country: 'UAE', tags: 'gratuity end of service' },
  { slug: 'uae/rental-yield-calculator', name: 'Dubai Rental Yield', country: 'UAE', tags: 'rental yield dubai property roi' },
  { slug: 'uae/vat-calculator', name: 'UAE VAT Calculator', country: 'UAE', tags: 'vat tax 5%' },
  { slug: 'us/compound-interest-calculator', name: 'Compound Interest', country: 'US', tags: 'compound interest savings' },
];
---

<BaseLayout
  title="CalcStack - Free Financial Calculators for India, UAE & US"
  description="Free online financial calculators. SIP calculator, EMI calculator, gratuity calculator, income tax calculator, and more tools for India, UAE, and US."
>
  <div style="text-align:center;padding:1.5rem 0 0.75rem;">
    <h1>Free Financial Calculators</h1>
    <p class="page-subtitle">India, UAE, and US. No signup.</p>
  </div>

  <input
    type="text"
    id="calc-search"
    placeholder="Search all calculators... (tax, SIP, EMI, gratuity, FIRE, loan, rental)"
    style="width:100%;padding:0.55rem 0.85rem;border:2px solid #e5e7eb;border-radius:8px;font-size:0.9rem;font-family:inherit;margin-bottom:0.75rem;background:#f9fafb;outline:none;"
    onfocus="this.style.borderColor='#6366f1'"
    onblur="this.style.borderColor='#e5e7eb'"
  />

  <div class="calc-grid" id="calc-grid">
    {allCalcs.map((calc) => (
      <a href={`/${calc.slug}`} class="calc-card" data-search={`${calc.name} ${calc.country} ${calc.tags}`.toLowerCase()}>
        <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#6b7280;letter-spacing:0.05em;">{calc.country}</span>
        <h3 style="margin:0.15rem 0 0;font-size:0.95rem;">{calc.name}</h3>
      </a>
    ))}
  </div>

  <div id="no-results" style="display:none;text-align:center;padding:1.5rem;color:#6b7280;font-size:0.9rem;">
    No calculators match your search.
  </div>
</BaseLayout>

<script is:inline>
document.getElementById('calc-search').addEventListener('input', function(e) {
  const q = e.target.value.toLowerCase().trim();
  const cards = document.querySelectorAll('#calc-grid .calc-card');
  let visible = 0;
  cards.forEach(card => {
    const match = !q || card.dataset.search.includes(q);
    card.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
});
</script>

<style>
  .calc-card h3 { font-size: 0.95rem; margin: 0; }
</style>
