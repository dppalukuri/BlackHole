---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

import AdScripts from '../components/AdScripts.astro';

const { title, description, canonicalUrl, ogImage } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://calcstack.techtools365.com';
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).toString();
const og = ogImage || `${siteUrl}/og-default.png`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={og} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CalcStack" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={og} />

  <!-- Ad scripts loaded from shared/ads.html (single source of truth) -->
  <AdScripts />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <slot name="head" />
</head>
<body>
  <div class="top-bar">
    <div class="container" style="display:flex;justify-content:space-between;align-items:center;">
      <a href="https://techtools365.com" style="color:#475569;font-size:0.8rem;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:0.5rem;">
        <span style="background:#6366f1;color:white;font-size:0.65rem;font-weight:700;padding:0.15rem 0.5rem;border-radius:4px;">TechTools365</span>
        Part of the TechTools365 ecosystem
      </a>
      <a href="https://techtools365.com" style="color:#6366f1;font-size:0.8rem;font-weight:600;text-decoration:none;">All tools &rarr;</a>
    </div>
  </div>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">Calc<span>Stack</span></a>
      <nav class="site-nav">
        <a href="/india/">India</a>
        <a href="/uae/">UAE</a>
        <a href="/us/">US</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p><a href="/about" style="color: inherit;">About</a> &middot; <a href="/privacy" style="color: inherit;">Privacy Policy</a> &middot; <a href="https://techtools365.com" style="color: inherit;">TechTools365</a></p>
      <p>&copy; {new Date().getFullYear()} CalcStack by TechTools365. Free financial calculators for India, UAE, and US.</p>
      <p>Calculations are for informational purposes only. Consult a financial advisor for personalized advice.</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
