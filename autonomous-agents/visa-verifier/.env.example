# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model.
# Default: claude-haiku-4-5 (cheap, ~$0.0015/query).
# Alternatives: claude-opus-4-7 (~10x cost, best quality), claude-sonnet-4-6 (~6x cost)
# VISA_VERIFIER_MODEL=claude-haiku-4-5

# Optional: max re-verify staleness in days (default: 30)
# VISA_VERIFIER_TTL_DAYS=30
