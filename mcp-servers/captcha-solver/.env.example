# ---- VLM Providers (at least one recommended) ----
# Gemini is FREE (250 solves/day). Recommended for starting out.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- External API fallback (optional, paid) ----
CAPSOLVER_API_KEY=
TWOCAPTCHA_API_KEY=

# ---- API Authentication ----
# Comma-separated list of valid client API keys.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=
# Or load from a file (one key per line):
# API_KEYS_FILE=/etc/captcha-solver/keys.txt

# ---- Rate Limiting ----
# Max requests per minute per API key (default: 30)
# Note: RapidAPI requests bypass this (RapidAPI enforces its own limits)
RATE_LIMIT_RPM=30

# ---- RapidAPI ----
# Proxy secret from your RapidAPI provider dashboard.
# Requests with matching X-RapidAPI-Proxy-Secret header are authenticated.
RAPIDAPI_PROXY_SECRET=

# ---- Server ----
HOST=0.0.0.0
PORT=8000
